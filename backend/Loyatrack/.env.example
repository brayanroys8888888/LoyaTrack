# Configuration backend Loyatrack — copier vers `.env` et renseigner les valeurs.
# NE JAMAIS committer le vrai fichier `.env` (il est gitignoré).

# --- Django ---
SECRET_KEY=change-me-genere-une-cle-secrete-longue-et-aleatoire
DEBUG=True

# --- Redis (broker Celery + résultats) ---
REDIS_URL=redis://localhost:6379/0

# --- Twilio (SMS / WhatsApp / appels vocaux) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# --- Abonnements / paiement ---
# 'fake' en développement (page de simulation) ; 'cinetpay' en production.
PAIEMENT_PROVIDER=fake
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_NOTIFY_URL=
CINETPAY_RETURN_URL=

# --- Firebase ---
# Le compte de service n'est PAS une variable d'environnement : place le fichier
# `firebase-adminsdk.json` dans backend/Loyatrack/ (lui aussi gitignoré).
