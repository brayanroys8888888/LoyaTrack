# Configuration backend Loyatrack — copier vers `.env` et renseigner les valeurs.
# NE JAMAIS committer le vrai fichier `.env` (il est gitignoré).

# --- Django ---
SECRET_KEY=change-me-genere-une-cle-secrete-longue-et-aleatoire
DEBUG=True

# --- Redis (broker Celery + résultats) ---
REDIS_URL=redis://localhost:6379/0

# --- Twilio (SMS / WhatsApp / appels vocaux) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# --- Abonnements / paiement ---
# 'fake' en développement (page de simulation) ; 'cinetpay' en production.
PAIEMENT_PROVIDER=fake
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_NOTIFY_URL=
CINETPAY_RETURN_URL=

# --- Firebase ---
# Le compte de service n'est PAS une variable d'environnement : place le fichier
# `firebase-adminsdk.json` dans backend/Loyatrack/ (lui aussi gitignoré).
# Firebase ne sert qu'aux notifications push (FCM), PAS au stockage des images.

# --- Stockage des médias (Cloudflare R2, S3-compatible) ---
# Laisser R2_BUCKET vide en dev (= disque local). En prod, renseigner pour des
# uploads persistants (pièces d'identité, photos d'état des lieux).
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
# Domaine public du bucket (R2 « Public access » → pub-xxxx.r2.dev, ou domaine perso)
R2_PUBLIC_DOMAIN=
